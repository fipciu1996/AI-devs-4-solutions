# Copy this file to `.env` and fill in the secrets before running the tasks.
# Stable AG3NTS hub endpoints are defined in code via devs_utilities.ag3nts.

# Common hub/API keys
AG3NTS_BASE_URL=https://example.invalid/
AG3NTS_API_KEY=replace-with-your-ag3nts-api-key
PACKAGES_API_KEY=replace-with-your-packages-api-key
AG3NTS_TIMEOUT_SECONDS=30

# OpenRouter
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_TIMEOUT_SECONDS=120
OPENROUTER_RETRY_ATTEMPTS=5
OPENROUTER_RETRY_BASE_DELAY_SECONDS=5
OPENROUTER_RETRY_MAX_DELAY_SECONDS=90
OPENROUTER_SITE_URL=https://openrouter.ai
OPENROUTER_SITE_NAME=OpenRouter
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=proxy-api-server
OPENROUTER_SYSTEM_PROMPT_FILE=
OPENROUTER_SYSTEM_PROMPT=

# Task-specific model fallbacks.
# When OPENROUTER_MODEL is set, solvers use it as the default everywhere.
CATEGORIZE_MODEL=
DOMATOWO_MODEL=
DRONE_MODEL=
ELECTRICITY_MODEL=
FAILURE_MODEL=
FILESYSTEM_MODEL=
FIRMWARE_MODEL=
MAILBOX_MODEL=
OKOEDITOR_MODEL=
PEOPLE_MODEL=
PHONECALL_STT_MODEL=openai/gpt-audio-mini
PHONECALL_TTS_MODEL=openai/gpt-audio
RADIOMONITORING_AUDIO_MODEL=openai/gpt-audio
RADIOMONITORING_VISION_MODEL=openai/gpt-4.1-nano
RAILWAY_MODEL=
REACTOR_MODEL=
SAVETHEM_MODEL=
SENDIT_MODEL=
SENSORS_MODEL=
SHELLACCESS_MODEL=

# Proxy server
API_HOST=0.0.0.0
API_PORT=18080
API_PATH=/mcp
CONVERSATION_LOG_FILE=conversation.log
MAX_CONTEXT_MESSAGES=20
MAX_TOOL_ROUND_TRIPS=8

# Package API
PACKAGES_API_URL=https://example.invalid/packages
PACKAGES_TIMEOUT_SECONDS=15

# Categorize
CATEGORIZE_ORDER_MODE=
CATEGORIZE_SEND_ORDER=

# Drone
DRONE_DESTINATION_OBJECT=
DRONE_DAM_SECTOR_X=
DRONE_DAM_SECTOR_Y=
DRONE_GRID_COLUMNS=3
DRONE_GRID_ROWS=4
DRONE_DEFAULT_POWER=100%
DRONE_DEFAULT_HEIGHT=10m

# Electricity
ELECTRICITY_ROTATION_SEQUENCE=

# Failure
FAILURE_TIMEOUT_SECONDS=60

# Firmware
FIRMWARE_MAX_STEPS=30
FIRMWARE_TIMEOUT_SECONDS=30

# Mailbox
MAILBOX_MAX_STEPS=24
MAILBOX_TOOL_PAGE_SIZE=5
MAILBOX_WAIT_SECONDS=5
MAILBOX_MAX_WAIT_SECONDS=30
MAILBOX_TIMEOUT_SECONDS=120

# People
PEOPLE_REFERENCE_DATE=
PEOPLE_BATCH_SIZE=25
PEOPLE_TIMEOUT_SECONDS=120

# Railway
RAILWAY_MAX_STEPS=8
RAILWAY_RETRY_ATTEMPTS=3
RAILWAY_RETRY_DELAY_503_SECONDS=30
RAILWAY_API_TIMEOUT_SECONDS=60

# Sensors
SENSORS_BATCH_SIZE=10
SENSORS_DOWNLOAD_TIMEOUT_SECONDS=60

# Sendit
SENDIT_TASK_NAME=sendit
SENDIT_SYSTEM_PROMPT_FILE=openrouter_system_prompt.txt
SENDIT_ANALYZE_MAX_TEXT_CHARS=24000

# Ngrok
NGROK_AUTH_TOKEN=replace-with-your-ngrok-auth-token
NGROK_DOMAIN=

# Langfuse
LANGFUSE_SECRET_KEY=replace-with-your-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=replace-with-your-langfuse-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Negotiations API server overrides (optional)
NEGOTIATIONS_API_HOST=0.0.0.0
NEGOTIATIONS_API_PORT=18081
NEGOTIATIONS_API_TOOL_PATH=/api/find-cities
NEGOTIATIONS_DATA_BASE_URL=
NEGOTIATIONS_DATA_CACHE_DIR=
NEGOTIATIONS_REQUEST_TIMEOUT_SECONDS=30
NEGOTIATIONS_MATCH_LIMIT=5
